#!/usr/bin/env bash
# LIFO stack for cycling through idle Claude Code sessions.
#
# Model:
#   - All idle (non-processing) user sessions form a stack
#   - New idle sessions enter at the TOP (most recently idle first)
#   - Pressing the shortcut: jumps to top, moves that session to BOTTOM
#   - When a session starts processing (user types): it leaves the stack
#   - Sub-claude sessions are excluded (detected via SUB_CLAUDE=1 env var,
#     meta.json session IDs, and temp directory patterns)
#
# Usage:
#   claude-next-idle              # Jump to next idle session (top of stack)
#   claude-next-idle --list       # Show the full stack
#   claude-next-idle --count      # Print idle + processing counts
#   claude-next-idle --reset      # Clear stack ordering
#   claude-next-idle --debug      # Jump with verbose logging to ~/claude-next-idle.log

set -euo pipefail

# Ensure tools are available regardless of how the script is launched (KM, cron, etc.)
export PATH="/opt/homebrew/bin:/usr/local/bin:$HOME/.local/bin:$PATH"

STACK_FILE="$HOME/.claude/idle-stack"
LOCK_DIR="$HOME/.claude/idle-stack.lock"
CLAUDE_DIR="$HOME/.claude/projects"
SUB_CLAUDE_DIR="$HOME/.sub-claude"
LOG_FILE="$HOME/claude-next-idle.log"
MAX_AGE_MIN=120
DEBUG=0

# --- logging ---

log() {
    [ "$DEBUG" -eq 0 ] && return
    echo "[$(date '+%H:%M:%S')] $*" >> "$LOG_FILE"
}

# --- locking (mkdir-based, works on macOS bash 3.2) ---

acquire_lock() {
    if ! mkdir "$LOCK_DIR" 2>/dev/null; then
        local lock_age
        lock_age=$(( $(date +%s) - $(stat -f %m "$LOCK_DIR" 2>/dev/null || echo 0) ))
        if [ "$lock_age" -gt 30 ]; then
            rm -rf "$LOCK_DIR" && mkdir "$LOCK_DIR" 2>/dev/null || exit 0
        else
            log "BLOCKED: another instance holds the lock (age=${lock_age}s)"
            exit 0
        fi
    fi
    trap 'rm -rf "$LOCK_DIR"' EXIT
}

# --- sub-claude exclusion ---

get_subclaude_ids() {
    {
        # 1. Running processes with SUB_CLAUDE=1 → get session ID from tasks/ dir
        for pid in $(pgrep -x claude 2>/dev/null); do
            ps eww -p "$pid" 2>/dev/null | grep -q "SUB_CLAUDE=1" || continue
            lsof -p "$pid" 2>/dev/null | grep "\.claude/tasks/" | head -1 \
                | awk '{print $NF}' | xargs basename 2>/dev/null
        done

        # 2. Session IDs from sub-claude job metadata
        find "$SUB_CLAUDE_DIR" -name "meta.json" -path "*/jobs/*" 2>/dev/null \
            | while read -r f; do
                python3 -c "import json,sys; print(json.load(open(sys.argv[1])).get('claude_session_id',''))" "$f" 2>/dev/null
            done
    } | grep -v '^$' | sort -u
}

is_subclaude_path() {
    [[ "$1" == *-tmp-* ]] || [[ "$1" == *tmp.* ]]
}

# --- session detection ---

# Build a set of session IDs that have a running claude process
get_live_session_ids() {
    for pid in $(pgrep -x claude 2>/dev/null); do
        lsof -p "$pid" 2>/dev/null | grep "\.claude/tasks/" | head -1 \
            | awk '{print $NF}' | xargs basename 2>/dev/null
    done | grep -v '^$' | sort -u
}

# Classify sessions. Output format: status|session_id|cwd|mtime
# status: idle or processing
get_sessions() {
    local subclaude_ids live_ids
    subclaude_ids=$(get_subclaude_ids)
    live_ids=$(get_live_session_ids)
    log "sub-claude IDs to exclude: $(echo "$subclaude_ids" | tr '\n' ' ')"
    log "live session IDs: $(echo "$live_ids" | tr '\n' ' ')"

    find "$CLAUDE_DIR" -name "*.jsonl" -mmin -"$MAX_AGE_MIN" 2>/dev/null | while read -r f; do
        local session proj_dir
        session=$(basename "$f" .jsonl)
        proj_dir=$(basename "$(dirname "$f")")

        [[ "$session" == agent-* ]] && continue
        is_subclaude_path "$proj_dir" && continue
        echo "$subclaude_ids" | grep -qxF "$session" && continue

        # Get last meaningful message type + CWD in one python call
        local info
        info=$(python3 -c "
import sys, json
SKIP = {'file-history-snapshot', 'system', 'progress', 'pr-link'}
cwd = ''
last = 'unknown'
with open(sys.argv[1]) as fh:
    for i, line in enumerate(fh):
        if i >= 10: break
        try:
            d = json.loads(line)
            if 'cwd' in d and not cwd:
                cwd = d['cwd']
        except: pass
    fh.seek(0)
    lines = fh.readlines()
    for line in lines[-50:]:
        try:
            d = json.loads(line)
            t = d.get('type', '')
            if t not in SKIP:
                last = t
        except: pass
print(f'{last}|{cwd}')
" "$f" 2>/dev/null)

        local last_type cwd
        last_type="${info%%|*}"
        cwd="${info#*|}"

        [ -z "$cwd" ] && continue
        [ -d "$cwd" ] || continue

        local mtime status
        mtime=$(stat -f %m "$f" 2>/dev/null || echo 0)

        if [ "$last_type" = "assistant" ]; then
            status="idle"
        elif [ "$last_type" = "user" ]; then
            # Only count as "processing" if the session is actually alive
            # (prevents ghost sessions from closed windows)
            if echo "$live_ids" | grep -qxF "$session" 2>/dev/null; then
                status="processing"
            else
                log "session $session: skipped (last=user but process dead)"
                continue
            fi
        else
            continue
        fi

        log "session $session: status=$status project=$(basename "$cwd")"
        echo "${status}|${session}|${cwd}|${mtime}"
    done
}

# --- stack management ---

rebuild_stack() {
    local idle_sessions="$1"
    local tmp_idle tmp_stack_ids tmp_new
    tmp_idle=$(mktemp)
    tmp_stack_ids=$(mktemp)
    tmp_new=$(mktemp)

    echo "$idle_sessions" | grep -v '^$' > "$tmp_idle" || true
    log "idle sessions found: $(wc -l < "$tmp_idle" | tr -d ' ')"

    local kept_lines=""
    if [ -f "$STACK_FILE" ]; then
        while IFS='|' read -r sid _rest; do
            [ -z "$sid" ] && continue
            if grep -qF "${sid}|" "$tmp_idle" 2>/dev/null; then
                local fresh_data
                fresh_data=$(grep -F "${sid}|" "$tmp_idle" | head -1)
                kept_lines="${kept_lines}${fresh_data}"$'\n'
                echo "$sid" >> "$tmp_stack_ids"
            fi
        done < "$STACK_FILE"
    fi

    while IFS='|' read -r sid cwd mtime; do
        [ -z "$sid" ] && continue
        if ! grep -qxF "$sid" "$tmp_stack_ids" 2>/dev/null; then
            echo "${mtime}|${sid}|${cwd}" >> "$tmp_new"
        fi
    done < "$tmp_idle"

    {
        sort -t'|' -k1 -rn "$tmp_new" 2>/dev/null | while IFS='|' read -r _mtime sid cwd; do
            [ -z "$sid" ] && continue
            grep -F "${sid}|" "$tmp_idle" | head -1
        done
        printf '%s' "$kept_lines"
    } | grep -v '^$' > "$STACK_FILE" || true

    rm -f "$tmp_idle" "$tmp_stack_ids" "$tmp_new"
    log "stack rebuilt: $(wc -l < "$STACK_FILE" | tr -d ' ') entries"
}

rotate_to_bottom() {
    local target="$1"
    local tmp
    tmp=$(mktemp)
    grep -vF "${target}|" "$STACK_FILE" > "$tmp" 2>/dev/null || true
    grep -F "${target}|" "$STACK_FILE" >> "$tmp" 2>/dev/null || true
    mv "$tmp" "$STACK_FILE"
}

# --- navigation ---

# Detect which app hosts the session: "cursor", "iterm", or "unknown"
detect_session_app() {
    local cwd="$1"
    local project_name
    project_name=$(basename "$cwd")

    local cursor_match
    cursor_match=$(osascript - "$project_name" <<'AS' 2>/dev/null || true
on run argv
    set pn to item 1 of argv
    tell application "System Events"
        if not (exists process "Cursor") then return "no"
        tell process "Cursor"
            repeat with w in windows
                if name of w contains pn then return "yes"
            end repeat
        end tell
    end tell
    return "no"
end run
AS
)
    if [ "$cursor_match" = "yes" ]; then
        echo "cursor"
        return
    fi

    local iterm_match
    iterm_match=$(osascript - "$project_name" <<'AS' 2>/dev/null || true
on run argv
    set pn to item 1 of argv
    tell application "System Events"
        if not (exists process "iTerm2") then return "no"
    end tell
    tell application "iTerm"
        repeat with w in windows
            repeat with t in tabs of w
                repeat with s in sessions of t
                    if name of s contains pn then return "yes"
                end repeat
            end repeat
        end repeat
    end tell
    return "no"
end run
AS
)
    if [ "$iterm_match" = "yes" ]; then
        echo "iterm"
        return
    fi

    echo "unknown"
}

activate_cursor_window() {
    local project_name="$1"
    log "activating Cursor window for: $project_name"

    # Safe: only raises the matching window, no keystrokes
    osascript - "$project_name" <<'APPLESCRIPT' 2>/dev/null
on run argv
    set projectName to item 1 of argv
    tell application "System Events"
        tell process "Cursor"
            set frontmost to true
            repeat with w in windows
                if name of w contains projectName then
                    perform action "AXRaise" of w
                    return "found"
                end if
            end repeat
            return "not_found"
        end tell
    end tell
end run
APPLESCRIPT
}

activate_iterm_session() {
    local project_name="$1"
    log "activating iTerm session for: $project_name"

    # iTerm has proper AppleScript support — bring matching window/tab to front
    osascript - "$project_name" <<'APPLESCRIPT' 2>/dev/null
on run argv
    set projectName to item 1 of argv
    tell application "iTerm"
        activate
        repeat with w in windows
            repeat with t in tabs of w
                repeat with s in sessions of t
                    if name of s contains projectName or name of s contains "claude" then
                        set index of w to 1
                        select t
                        return "found"
                    end if
                end repeat
            end repeat
        end repeat
    end tell
    return "not_found"
end run
APPLESCRIPT
}

navigate_to_session() {
    local cwd="$1"
    local project_name
    project_name=$(basename "$cwd")

    local app
    app=$(detect_session_app "$cwd")
    log "detected app: $app for project: $project_name"

    case "$app" in
        cursor)
            activate_cursor_window "$project_name"
            ;;
        iterm)
            activate_iterm_session "$project_name"
            ;;
        *)
            log "no matching window found in Cursor or iTerm"
            echo "not_found"
            ;;
    esac
}

# --- main ---

# Parse flags
for arg in "$@"; do
    case "$arg" in
        --debug) DEBUG=1; shift ;;
    esac
done

if [ "$DEBUG" -eq 1 ]; then
    echo "=== claude-next-idle debug $(date) ===" >> "$LOG_FILE"
    log "PATH=$PATH"
    log "python3=$(which python3 2>/dev/null || echo MISSING)"
    log "pgrep=$(which pgrep 2>/dev/null || echo MISSING)"
    log "osascript=$(which osascript 2>/dev/null || echo MISSING)"
fi

acquire_lock

all_sessions=$(get_sessions)
idle_sessions=$(echo "$all_sessions" | grep "^idle|" | sed 's/^idle|//' || true)
processing_sessions=$(echo "$all_sessions" | grep "^processing|" | sed 's/^processing|//' || true)
idle_count=$(echo "$idle_sessions" | grep -c '|' 2>/dev/null) || idle_count=0
processing_count=$(echo "$processing_sessions" | grep -c '|' 2>/dev/null) || processing_count=0
log "totals: idle=$idle_count processing=$processing_count"

rebuild_stack "$idle_sessions"

case "${1:-}" in
    --list)
        echo "Idle (review stack):"
        pos=1
        if [ -f "$STACK_FILE" ]; then
            while IFS='|' read -r sid cwd _mtime; do
                [ -z "$sid" ] && continue
                project=$(basename "$cwd")
                printf "  %2d. %s\n" "$pos" "$project"
                pos=$((pos + 1))
            done < "$STACK_FILE"
        fi
        [ "$((pos - 1))" -eq 0 ] && echo "  (none)"
        echo ""
        echo "Processing:"
        if [ "$processing_count" -gt 0 ]; then
            echo "$processing_sessions" | while IFS='|' read -r _sid cwd _mtime; do
                [ -z "$cwd" ] && continue
                echo "  ⟳ $(basename "$cwd")"
            done
        else
            echo "  (none)"
        fi
        exit 0
        ;;
    --count)
        echo "${idle_count}/${processing_count}"
        exit 0
        ;;
    --reset)
        rm -f "$STACK_FILE"
        echo "Stack cleared."
        exit 0
        ;;
esac

# Default: jump to top of stack
top=$(head -1 "$STACK_FILE" 2>/dev/null || true)
if [ -z "$top" ]; then
    log "no idle sessions to jump to"
    echo "No idle sessions.  (${processing_count} processing)"
    afplay /System/Library/Sounds/Tink.aiff 2>/dev/null &
    exit 0
fi

IFS='|' read -r sid cwd _mtime <<< "$top"
project=$(basename "$cwd")
log "jumping to: $project ($sid)"

rotate_to_bottom "$sid"

result=$(navigate_to_session "$cwd")
remaining=$(grep -c '|' "$STACK_FILE" 2>/dev/null) || remaining=0
remaining=$((remaining - 1))

if [ "$result" = "found" ]; then
    echo "→ $project  ($remaining more, ${processing_count} processing)"
else
    log "FAILED: window not found for $project"
    echo "→ $project  [not found in Cursor or iTerm]  ($remaining more, ${processing_count} processing)"
fi
