#!/usr/bin/env bash
# LIFO stack for cycling through idle Claude Code sessions.
#
# Model:
#   - Idle sessions are detected via hook-written signal files
#     (~/.claude/idle-signals/<pid>), NOT by parsing JSONL files.
#   - Hooks: Stop, PreToolUse(AskUserQuestion|ExitPlanMode),
#     PermissionRequest → write signal. PostToolUse, UserPromptSubmit → clear.
#   - New idle sessions enter at the TOP (most recently idle first)
#   - Pressing the shortcut: jumps to top, moves that session to BOTTOM
#   - Sub-claude sessions never write signals (hook checks SUB_CLAUDE=1)
#
# Usage:
#   claude-next-idle              # Jump to next idle session (top of stack)
#   claude-next-idle --list       # Show the full stack
#   claude-next-idle --count      # Print idle + processing counts
#   claude-next-idle --reset      # Clear stack ordering
#   claude-next-idle --debug      # Jump with verbose logging to ~/claude-next-idle.log

set -euo pipefail

# Ensure tools are available regardless of how the script is launched (KM, cron, etc.)
export PATH="/opt/homebrew/bin:/usr/local/bin:$HOME/.local/bin:$PATH"

STACK_FILE="$HOME/.claude/idle-stack"
LOCK_DIR="$HOME/.claude/idle-stack.lock"
SIGNAL_DIR="$HOME/.claude/idle-signals"
LOG_FILE="$HOME/claude-next-idle.log"
DEBUG=0

# --- logging ---

log() {
    [ "$DEBUG" -eq 0 ] && return
    echo "[$(date '+%H:%M:%S')] $*" >> "$LOG_FILE"
}

# --- locking (mkdir-based, works on macOS bash 3.2) ---

acquire_lock() {
    if ! mkdir "$LOCK_DIR" 2>/dev/null; then
        local lock_age
        lock_age=$(( $(date +%s) - $(stat -f %m "$LOCK_DIR" 2>/dev/null || echo 0) ))
        if [ "$lock_age" -gt 30 ]; then
            rm -rf "$LOCK_DIR" && mkdir "$LOCK_DIR" 2>/dev/null || exit 0
        else
            log "BLOCKED: another instance holds the lock (age=${lock_age}s)"
            exit 0
        fi
    fi
    trap 'rm -rf "$LOCK_DIR"' EXIT
}

# --- session detection (signal-file based) ---

# Read idle sessions from signal files. Output: pid|cwd|ts per idle session.
# Each signal file is ~/.claude/idle-signals/<pid> written by hooks.
# Stale signals (dead PIDs) are cleaned up.
get_idle_sessions() {
    mkdir -p "$SIGNAL_DIR"
    for signal_file in "$SIGNAL_DIR"/*; do
        [ -f "$signal_file" ] || continue
        local pid cwd ts
        pid=$(basename "$signal_file")

        # Verify PID is still alive and is a claude process
        if ! ps -o comm= -p "$pid" 2>/dev/null | grep -qx "claude"; then
            log "cleaning stale signal: PID=$pid (dead)"
            rm -f "$signal_file"
            continue
        fi

        # Parse signal metadata
        cwd=$(python3 -c "import json,sys; print(json.load(sys.stdin).get('cwd',''))" < "$signal_file" 2>/dev/null) || true
        ts=$(python3 -c "import json,sys; print(json.load(sys.stdin).get('ts',0))" < "$signal_file" 2>/dev/null) || true

        [ -z "$cwd" ] && continue
        log "idle signal: PID=$pid CWD=$cwd TS=$ts"
        echo "${pid}|${cwd}|${ts}"
    done
}

# Count processing sessions: alive claude PIDs that are NOT idle and NOT sub-claude.
get_processing_sessions() {
    local idle_pids="$1"
    local ps_eww
    ps_eww=$(ps eww $(ps -eo pid=,comm= 2>/dev/null | awk '$2 == "claude" {printf "%s ", $1}') 2>/dev/null) || true
    [ -z "$ps_eww" ] && return

    ps -eo pid=,comm= 2>/dev/null | awk '$2 == "claude" {print $1}' | while read -r pid; do
        # Skip sub-claude
        echo "$ps_eww" | grep "^[[:space:]]*${pid} " | grep -q "SUB_CLAUDE=1" && continue
        # Skip idle
        echo "$idle_pids" | grep -qxF "$pid" && continue
        # Get CWD
        local cwd
        cwd=$(echo "$ps_eww" | grep "^[[:space:]]*${pid} " | grep -oE '[[:space:]]PWD=[^[:space:]]+' | head -1 | sed 's/^[[:space:]]*PWD=//')
        [ -z "$cwd" ] && continue
        echo "${pid}|${cwd}"
    done
}

# --- stack management ---

# Stack file format: pid|cwd|ts
rebuild_stack() {
    local idle_sessions="$1"
    local tmp_idle tmp_stack_pids tmp_new
    tmp_idle=$(mktemp)
    tmp_stack_pids=$(mktemp)
    tmp_new=$(mktemp)

    echo "$idle_sessions" | grep -v '^$' > "$tmp_idle" || true
    log "idle sessions found: $(wc -l < "$tmp_idle" | tr -d ' ')"

    # Preserve ordering of sessions already in the stack (keyed by PID)
    local kept_lines=""
    if [ -f "$STACK_FILE" ]; then
        while IFS='|' read -r pid _rest; do
            [ -z "$pid" ] && continue
            if grep -q "^${pid}|" "$tmp_idle" 2>/dev/null; then
                local fresh_data
                fresh_data=$(grep "^${pid}|" "$tmp_idle" | head -1)
                kept_lines="${kept_lines}${fresh_data}"$'\n'
                echo "$pid" >> "$tmp_stack_pids"
            fi
        done < "$STACK_FILE"
    fi

    # New sessions not yet in the stack
    while IFS='|' read -r pid cwd ts; do
        [ -z "$pid" ] && continue
        if ! grep -qxF "$pid" "$tmp_stack_pids" 2>/dev/null; then
            echo "${ts}|${pid}|${cwd}|${ts}" >> "$tmp_new"
        fi
    done < "$tmp_idle"

    # Stack = new sessions (sorted by ts desc, at top) + existing sessions (preserved order)
    {
        sort -t'|' -k1 -rn "$tmp_new" 2>/dev/null | while IFS='|' read -r _sort_ts pid cwd ts; do
            [ -z "$pid" ] && continue
            echo "${pid}|${cwd}|${ts}"
        done
        printf '%s' "$kept_lines"
    } | grep -v '^$' > "$STACK_FILE" || true

    rm -f "$tmp_idle" "$tmp_stack_pids" "$tmp_new"
    log "stack rebuilt: $(wc -l < "$STACK_FILE" | tr -d ' ') entries"
}

rotate_to_bottom() {
    local target="$1"
    local tmp
    tmp=$(mktemp)
    grep -v "^${target}|" "$STACK_FILE" > "$tmp" 2>/dev/null || true
    grep "^${target}|" "$STACK_FILE" >> "$tmp" 2>/dev/null || true
    mv "$tmp" "$STACK_FILE"
}

# --- navigation ---

# Detect which app hosts the session: "iterm", "cursor", or "unknown"
# iTerm checked first — Claude sessions run there; Cursor windows match
# project name in their editor title bar, which would cause false matches.
detect_session_app() {
    local cwd="$1"
    local project_name
    project_name=$(basename "$cwd")

    local iterm_match
    iterm_match=$(osascript - "$project_name" <<'AS' 2>/dev/null || true
on run argv
    set pn to item 1 of argv
    tell application "System Events"
        if not (exists process "iTerm2") then return "no"
    end tell
    tell application "iTerm"
        repeat with w in windows
            repeat with t in tabs of w
                repeat with s in sessions of t
                    if name of s contains pn then return "yes"
                end repeat
            end repeat
        end repeat
    end tell
    return "no"
end run
AS
)
    if [ "$iterm_match" = "yes" ]; then
        echo "iterm"
        return
    fi

    local cursor_match
    cursor_match=$(osascript - "$project_name" <<'AS' 2>/dev/null || true
on run argv
    set pn to item 1 of argv
    tell application "System Events"
        if not (exists process "Cursor") then return "no"
        tell process "Cursor"
            repeat with w in windows
                if name of w contains pn then return "yes"
            end repeat
        end tell
    end tell
    return "no"
end run
AS
)
    if [ "$cursor_match" = "yes" ]; then
        echo "cursor"
        return
    fi

    echo "unknown"
}

activate_cursor_window() {
    local project_name="$1"
    log "activating Cursor window for: $project_name"

    osascript - "$project_name" <<'APPLESCRIPT' 2>/dev/null
on run argv
    set projectName to item 1 of argv
    tell application "System Events"
        tell process "Cursor"
            set frontmost to true
            repeat with w in windows
                if name of w contains projectName then
                    perform action "AXRaise" of w
                    return "found"
                end if
            end repeat
            return "not_found"
        end tell
    end tell
end run
APPLESCRIPT
}

activate_iterm_by_tty() {
    local tty_dev="$1"
    log "activating iTerm session by TTY: $tty_dev"

    osascript - "$tty_dev" <<'APPLESCRIPT' 2>/dev/null
on run argv
    set ttyDev to item 1 of argv
    tell application "iTerm"
        activate
        repeat with w in windows
            repeat with t in tabs of w
                repeat with s in sessions of t
                    if tty of s is ttyDev then
                        set index of w to 1
                        select t
                        select s
                        return "found"
                    end if
                end repeat
            end repeat
        end repeat
    end tell
    return "not_found"
end run
APPLESCRIPT
}

navigate_to_session() {
    local cwd="$1"
    local pid="$2"
    local project_name
    project_name=$(basename "$cwd")

    # Try iTerm by TTY first (most reliable — matches exact terminal session)
    if [ -n "$pid" ]; then
        local tty
        tty=$(ps -o tty= -p "$pid" 2>/dev/null | tr -d ' ')
        if [ -n "$tty" ] && [ "$tty" != "??" ]; then
            log "found TTY $tty for PID $pid (project: $project_name)"
            local result
            result=$(activate_iterm_by_tty "/dev/$tty")
            if [ "$result" = "found" ]; then
                echo "found"
                return
            fi
        fi
    fi

    # Fallback: detect by project name in window/session titles
    local app
    app=$(detect_session_app "$cwd")
    log "detected app: $app for project: $project_name"

    case "$app" in
        cursor)
            activate_cursor_window "$project_name"
            ;;
        iterm)
            osascript - "$project_name" <<'APPLESCRIPT' 2>/dev/null
on run argv
    set projectName to item 1 of argv
    tell application "iTerm"
        activate
        repeat with w in windows
            repeat with t in tabs of w
                repeat with s in sessions of t
                    if name of s contains projectName then
                        set index of w to 1
                        select t
                        return "found"
                    end if
                end repeat
            end repeat
        end repeat
    end tell
    return "not_found"
end run
APPLESCRIPT
            ;;
        *)
            log "no matching window found in Cursor or iTerm"
            echo "not_found"
            ;;
    esac
}

# --- main ---

# Parse flags
MODE=""
for arg in "$@"; do
    case "$arg" in
        --debug) DEBUG=1 ;;
        --list|--count|--reset) MODE="$arg" ;;
    esac
done

if [ "$DEBUG" -eq 1 ]; then
    echo "=== claude-next-idle debug $(date) ===" >> "$LOG_FILE"
    log "PATH=$PATH"
    log "python3=$(which python3 2>/dev/null || echo MISSING)"
    log "osascript=$(which osascript 2>/dev/null || echo MISSING)"
fi

acquire_lock

idle_sessions=$(get_idle_sessions)
idle_pids=$(echo "$idle_sessions" | awk -F'|' '{print $1}' | grep -v '^$' || true)
processing_sessions=$(get_processing_sessions "$idle_pids")
idle_count=$(echo "$idle_sessions" | grep -c '|' 2>/dev/null) || idle_count=0
processing_count=$(echo "$processing_sessions" | grep -c '|' 2>/dev/null) || processing_count=0
log "totals: idle=$idle_count processing=$processing_count"

rebuild_stack "$idle_sessions"

case "$MODE" in
    --list)
        echo "Idle (review stack):"
        pos=1
        if [ -f "$STACK_FILE" ]; then
            # Detect duplicate project names for disambiguation
            dup_names=$(while IFS='|' read -r _pid cwd _ts; do
                basename "$cwd" 2>/dev/null
            done < "$STACK_FILE" | sort | uniq -d)

            while IFS='|' read -r pid cwd _ts; do
                [ -z "$pid" ] && continue
                project=$(basename "$cwd")
                if echo "$dup_names" | grep -qxF "$project" 2>/dev/null; then
                    printf "  %2d. %s (PID %s)\n" "$pos" "$project" "$pid"
                else
                    printf "  %2d. %s\n" "$pos" "$project"
                fi
                pos=$((pos + 1))
            done < "$STACK_FILE"
        fi
        [ "$((pos - 1))" -eq 0 ] && echo "  (none)"
        echo ""
        echo "Processing:"
        if [ "$processing_count" -gt 0 ]; then
            echo "$processing_sessions" | while IFS='|' read -r _pid cwd; do
                [ -z "$cwd" ] && continue
                echo "  ⟳ $(basename "$cwd")"
            done
        else
            echo "  (none)"
        fi
        exit 0
        ;;
    --count)
        echo "${idle_count}/${processing_count}"
        exit 0
        ;;
    --reset)
        rm -f "$STACK_FILE"
        echo "Stack cleared."
        exit 0
        ;;
esac

# Default: jump to top of stack
top=$(head -1 "$STACK_FILE" 2>/dev/null || true)
if [ -z "$top" ]; then
    log "no idle sessions to jump to"
    echo "No idle sessions.  (${processing_count} processing)"
    afplay /System/Library/Sounds/Tink.aiff 2>/dev/null &
    exit 0
fi

IFS='|' read -r pid cwd _ts <<< "$top"
project=$(basename "$cwd")
log "jumping to: $project (PID=$pid)"

rotate_to_bottom "$pid"

result=$(navigate_to_session "$cwd" "$pid")
remaining=$(grep -c '|' "$STACK_FILE" 2>/dev/null) || remaining=0
remaining=$((remaining - 1))

if [ "$result" = "found" ]; then
    echo "→ $project  ($remaining more, ${processing_count} processing)"
else
    log "FAILED: window not found for $project"
    echo "→ $project  [not found]  ($remaining more, ${processing_count} processing)"
fi