#!/usr/bin/env bash
# LIFO stack for cycling through idle Claude Code sessions.
#
# Model:
#   - Idle sessions are detected via hook-written signal files
#     (~/.claude/idle-signals/<pid>), NOT by parsing JSONL files.
#   - Hooks: Stop, PreToolUse(AskUserQuestion|ExitPlanMode),
#     PermissionRequest → write signal. PostToolUse, UserPromptSubmit → clear.
#   - New idle sessions enter at the TOP (most recently idle first)
#   - Pressing the shortcut: jumps to top, moves that session to BOTTOM
#   - Sub-claude sessions never write signals (hook checks SUB_CLAUDE=1)
#
# Usage:
#   claude-next-idle              # Jump to next idle session (top of stack)
#   claude-next-idle --list       # Show the full stack
#   claude-next-idle --count      # Print idle + processing counts
#   claude-next-idle --reset      # Clear stack ordering
#   claude-next-idle --debug      # Jump with verbose logging to ~/claude-next-idle.log

set -euo pipefail

# Ensure tools are available regardless of how the script is launched (KM, cron, etc.)
export PATH="/opt/homebrew/bin:/usr/local/bin:$HOME/.local/bin:$PATH"

STACK_FILE="$HOME/.claude/idle-stack"
LOCK_DIR="$HOME/.claude/idle-stack.lock"
SIGNAL_DIR="$HOME/.claude/idle-signals"
LOG_FILE="$HOME/claude-next-idle.log"
DEBUG=0

# --- shared libs ---

# Resolve symlinks so sourcing works from ~/.local/bin/ symlinks
_self="$0"; [ -L "$_self" ] && _self=$(readlink "$_self")
SCRIPT_DIR="$(cd "$(dirname "$_self")" && pwd)"
# shellcheck source=../lib/stack.sh
. "$SCRIPT_DIR/../lib/stack.sh"
# shellcheck source=../lib/navigate.sh
. "$SCRIPT_DIR/../lib/navigate.sh"

# --- idle-specific: processing session detection ---

# Count processing sessions: alive claude PIDs that are NOT idle and NOT sub-claude.
get_processing_sessions() {
    local idle_pids="$1"
    local ps_eww
    ps_eww=$(ps eww $(ps -eo pid=,comm= 2>/dev/null | awk '$2 == "claude" {printf "%s ", $1}') 2>/dev/null) || true
    [ -z "$ps_eww" ] && return

    ps -eo pid=,comm= 2>/dev/null | awk '$2 == "claude" {print $1}' | while read -r pid; do
        # Skip sub-claude
        echo "$ps_eww" | grep "^[[:space:]]*${pid} " | grep -q "SUB_CLAUDE=1" && continue
        # Skip idle
        echo "$idle_pids" | grep -qxF "$pid" && continue
        # Get CWD
        local cwd
        cwd=$(echo "$ps_eww" | grep "^[[:space:]]*${pid} " | grep -oE '[[:space:]]PWD=[^[:space:]]+' | head -1 | sed 's/^[[:space:]]*PWD=//')
        [ -z "$cwd" ] && continue
        echo "${pid}|${cwd}"
    done
}

# --- main ---

parse_flags "$@"
init_debug "claude-next-idle"
acquire_lock

sessions=$(get_sessions)
idle_pids=$(echo "$sessions" | awk -F'|' '{print $1}' | grep -v '^$' || true)
processing_sessions=$(get_processing_sessions "$idle_pids")
session_count=$(echo "$sessions" | grep -c '|' 2>/dev/null) || session_count=0
processing_count=$(echo "$processing_sessions" | grep -c '|' 2>/dev/null) || processing_count=0
log "totals: idle=$session_count processing=$processing_count"

rebuild_stack "$sessions"

case "$MODE" in
    --list)
        echo "Idle (review stack):"
        print_stack_list
        echo ""
        echo "Processing:"
        if [ "$processing_count" -gt 0 ]; then
            echo "$processing_sessions" | while IFS='|' read -r _pid cwd; do
                [ -z "$cwd" ] && continue
                echo "  ⟳ $(basename "$cwd")"
            done
        else
            echo "  (none)"
        fi
        exit 0
        ;;
    --count)
        echo "${session_count}/${processing_count}"
        exit 0
        ;;
    --reset)
        rm -f "$STACK_FILE"
        echo "Stack cleared."
        exit 0
        ;;
esac

# Default: jump to top of stack
if ! jump_to_top ", ${processing_count} processing"; then
    log "no idle sessions to jump to"
    echo "No idle sessions.  (${processing_count} processing)"
    afplay /System/Library/Sounds/Tink.aiff 2>/dev/null &
fi
