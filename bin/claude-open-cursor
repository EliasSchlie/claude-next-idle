#!/usr/bin/env bash
# Opens Cursor at the project of the Claude session running in the
# frontmost iTerm window.
#
# How it works:
#   1. Gets the TTY of the active iTerm session via AppleScript
#   2. Finds the Claude process on that TTY → gets its CWD (= project root)
#   3. Falls back to parent shell CWD if no Claude process found
#   4. Opens Cursor there (workspace file if available, otherwise folder)
#
# Usage:
#   claude-open-cursor           # Open Cursor at Claude's current dir
#   claude-open-cursor --debug   # Same, with logging to ~/claude-next-idle.log

set -euo pipefail

export PATH="/opt/homebrew/bin:/usr/local/bin:$HOME/.local/bin:$PATH"

LOG_FILE="$HOME/claude-next-idle.log"
DEBUG=0

for arg in "$@"; do
    case "$arg" in
        --debug) DEBUG=1 ;;
    esac
done

log() {
    [ "$DEBUG" -eq 0 ] && return
    echo "[$(date '+%H:%M:%S')] open-cursor: $*" >> "$LOG_FILE"
}

# 1. Get the TTY of the frontmost iTerm session
tty_path=$(osascript -e '
tell application "iTerm"
    tty of (current session of current window)
end tell
' 2>/dev/null) || true

if [ -z "$tty_path" ]; then
    echo "No active iTerm session found." >&2
    exit 1
fi

tty_name="${tty_path##*/}"
log "TTY: $tty_path ($tty_name)"

# 2. Get project directory from the Claude process on this TTY
#    Claude's process CWD = the directory where it was launched = project root.
#    This is reliable because Bash tool calls run in subprocesses and don't
#    change the parent Claude process's CWD.
claude_pid=$(ps -t "$tty_name" -o pid=,comm= 2>/dev/null \
    | awk '$2 == "claude" {print $1; exit}')
log "Claude PID: ${claude_pid:-(not found)}"

cwd=""
if [ -n "$claude_pid" ]; then
    cwd=$(lsof -a -p "$claude_pid" -d cwd -F n 2>/dev/null \
        | awk '/^n/{print substr($0,2)}')
    log "Claude CWD: $cwd"
fi

# 3. Fallback: parent shell's CWD
if [ -z "$cwd" ] || [ ! -d "$cwd" ]; then
    shell_pid=$(ps -t "$tty_name" -o pid=,comm= 2>/dev/null \
        | awk '$2 ~ /^-?(bash|zsh|sh|fish)$/ {print $1; exit}')
    if [ -n "$shell_pid" ]; then
        cwd=$(lsof -a -p "$shell_pid" -d cwd -F n 2>/dev/null \
            | awk '/^n/{print substr($0,2)}')
        log "Fallback to shell CWD: $cwd"
    fi
fi

if [ -z "$cwd" ] || [ ! -d "$cwd" ]; then
    echo "Could not determine working directory." >&2
    exit 1
fi

# 4. Open in Cursor — check for matching workspace, then in-folder, then plain folder
WORKSPACE_DIR="$HOME/Documents/Projects/VS code workspaces"
project_name=$(basename "$cwd")

# Home directory → dotfiles workspace
if [ "$cwd" = "$HOME" ]; then
    project_name="dotfiles"
fi

# Use open -a instead of cursor CLI — the cursor CLI uses eval internally
# which breaks paths containing spaces (e.g. "VS code workspaces/...")
open_cursor() {
    open -a "Cursor" "$1"
}

# First: workspace file matching the project name
workspace="${WORKSPACE_DIR}/${project_name}.code-workspace"
if [ -f "$workspace" ]; then
    log "Opening workspace: $workspace"
    open_cursor "$workspace"
    exit 0
fi

# Second: .code-workspace file inside the folder itself
local_workspace=$(find "$cwd" -maxdepth 1 -name "*.code-workspace" -print -quit 2>/dev/null) || true
if [ -n "$local_workspace" ]; then
    log "Opening local workspace: $local_workspace"
    open_cursor "$local_workspace"
    exit 0
fi

# Third: just open the folder
log "Opening folder: $cwd"
open_cursor "$cwd"
