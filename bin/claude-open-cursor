#!/usr/bin/env bash
# Opens Cursor at the current working directory of the Claude session
# running in the frontmost iTerm window.
#
# How it works:
#   1. Gets the TTY of the active iTerm session via AppleScript
#   2. Gets parent shell CWD → encodes to find JSONL project dir
#   3. Reads the last `cwd` field from the most recent JSONL (tracks cd)
#   4. Falls back to parent shell CWD if no JSONL match
#   5. Opens Cursor there (reuses existing window if available)
#
# Usage:
#   claude-open-cursor           # Open Cursor at Claude's current dir
#   claude-open-cursor --debug   # Same, with logging to ~/claude-next-idle.log

set -euo pipefail

export PATH="/opt/homebrew/bin:/usr/local/bin:$HOME/.local/bin:$PATH"

LOG_FILE="$HOME/claude-next-idle.log"
CLAUDE_DIR="$HOME/.claude/projects"
DEBUG=0

for arg in "$@"; do
    case "$arg" in
        --debug) DEBUG=1 ;;
    esac
done

log() {
    [ "$DEBUG" -eq 0 ] && return
    echo "[$(date '+%H:%M:%S')] open-cursor: $*" >> "$LOG_FILE"
}

# 1. Get the TTY of the frontmost iTerm session
tty_path=$(osascript -e '
tell application "iTerm"
    tty of (current session of current window)
end tell
' 2>/dev/null) || true

if [ -z "$tty_path" ]; then
    echo "No active iTerm session found." >&2
    exit 1
fi

tty_name="${tty_path##*/}"
log "TTY: $tty_path ($tty_name)"

# 2. Get the parent shell's CWD (= project root where claude was launched)
shell_pid=$(ps -t "$tty_name" -o pid=,comm= 2>/dev/null \
    | awk '$2 ~ /^-?(bash|zsh|sh|fish)$/ {print $1; exit}')

shell_cwd=""
if [ -n "$shell_pid" ]; then
    shell_cwd=$(lsof -a -p "$shell_pid" -d cwd -F n 2>/dev/null \
        | awk '/^n/{print substr($0,2)}')
    log "Shell CWD: $shell_cwd"
fi

# 3. Try to get Claude's live CWD from the session JSONL
#    Project path encodes as: /Users/me/proj → -Users-me-proj
cwd=""
if [ -n "$shell_cwd" ]; then
    encoded_path=$(echo "$shell_cwd" | tr '/' '-')
    proj_dir="$CLAUDE_DIR/$encoded_path"

    if [ -d "$proj_dir" ]; then
        # Find the most recently modified JSONL in this project dir
        jsonl=$(ls -t "$proj_dir"/*.jsonl 2>/dev/null | head -1)

        if [ -n "$jsonl" ]; then
            log "JSONL: $jsonl"
            cwd=$(tail -100 "$jsonl" | python3 -c "
import sys, json
cwd = ''
for line in sys.stdin:
    try:
        c = json.loads(line).get('cwd', '')
        if c:
            cwd = c
    except:
        pass
print(cwd)
" 2>/dev/null)
            log "JSONL CWD: $cwd"
        fi
    fi
fi

# 4. Fallback to shell CWD if JSONL approach failed
if [ -z "$cwd" ] || [ ! -d "$cwd" ]; then
    cwd="$shell_cwd"
    log "Fallback to shell CWD: $cwd"
fi

if [ -z "$cwd" ] || [ ! -d "$cwd" ]; then
    echo "Could not determine working directory." >&2
    exit 1
fi

# 5. Open in Cursor — check for matching workspace, then in-folder, then plain folder
WORKSPACE_DIR="$HOME/Documents/Projects/VS code workspaces"
project_name=$(basename "$cwd")

# First: workspace file matching the project name
workspace="${WORKSPACE_DIR}/${project_name}.code-workspace"
if [ -f "$workspace" ]; then
    log "Opening workspace: $workspace"
    cursor "$workspace"
    exit 0
fi

# Second: .code-workspace file inside the folder itself
local_workspace=$(find "$cwd" -maxdepth 1 -name "*.code-workspace" -print -quit 2>/dev/null) || true
if [ -n "$local_workspace" ]; then
    log "Opening local workspace: $local_workspace"
    cursor "$local_workspace"
    exit 0
fi

# Third: just open the folder
log "Opening folder: $cwd"
cursor "$cwd"
